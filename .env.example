APP_NAME=DocuTracker
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL local development database
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=docutracker
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Security / Performance monitoring
FORCE_HTTPS=false
CSP_ENABLED=true
STRIP_HTML_INPUT=true
SLOW_REQUEST_THRESHOLD_MS=1500
PERFORMANCE_MONITORING_WINDOW_MINUTES=60

BROADCAST_CONNECTION=log
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@docutracker.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Authentication / OTP / Email Verification
MFA_EMAIL_ENABLED=true
MFA_FORCE_FOR_ALL=false
MFA_CODE_TTL_MINUTES=10
EMAIL_VERIFICATION_REQUIRED=false
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
FAILED_LOGIN_WARNING_THRESHOLD=3
FAILED_LOGIN_LOCKOUT_THRESHOLD=5
FAILED_LOGIN_LOCKOUT_MINUTES=30

BACKUP_NOTIFICATION_EMAIL=
BACKUP_CLOUD_DISK=
BACKUP_EXTERNAL_PATH=
BACKUP_EMAIL_ATTACH_LIMIT_MB=20
BACKUP_PG_DUMP_BINARY=pg_dump
PG_DUMP_BINARY=pg_dump
BACKUP_PROCESS_TIMEOUT_SECONDS=300

# Optional Supabase Storage backup integration.
# Set BACKUP_CLOUD_DISK=supabase or SUPABASE_BACKUP_ENABLED=true to store backup ZIPs in Supabase-compatible S3 storage.
SUPABASE_BACKUP_ENABLED=false
SUPABASE_BACKUP_PREFIX=docutracker-backups
SUPABASE_STORAGE_ACCESS_KEY_ID=
SUPABASE_STORAGE_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_REGION=us-east-1
SUPABASE_STORAGE_BUCKET=docutracker-backups
SUPABASE_STORAGE_ENDPOINT=
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_USE_PATH_STYLE_ENDPOINT=true

REPORT_NOTIFICATION_EMAIL=
ADMIN_ALERT_EMAIL=
SECURITY_ALERT_EMAIL=
STORAGE_CAPACITY_LIMIT_MB=1024
STORAGE_WARNING_THRESHOLD_PERCENT=85

# Developer safe simulation controls are stored in site_settings.
# Seeded defaults: audit.archive_after_days=90, audit.default_page_size=25, developer.max_simulation_events_per_run=100.

OCR_ENABLED=false
TESSERACT_PATH=tesseract
PDFTOTEXT_PATH=pdftotext
PDFTOPPM_PATH=pdftoppm
OCR_MAX_PDF_PAGES=3

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT=30

# Notifications / Real-Time Updates
NOTIFICATIONS_REALTIME_ENABLED=true
NOTIFICATIONS_SSE_RECONNECT_SECONDS=5
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=false
SMS_PROVIDER=placeholder
SMS_API_KEY=
SMS_FROM=


# Local mail testing option used in development when SMTP is not configured:
# MAIL_MAILER=log
# MAIL_HOST=127.0.0.1
# MAIL_PORT=2525
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
